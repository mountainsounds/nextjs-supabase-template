# Supabase — point this at your QA project for local dev
# Copy this file to .env.local and fill in values from the ichi-qa Supabase project.
#
# Where to find each value (Supabase dashboard → ichi-qa → Settings → API):
#   NEXT_PUBLIC_SUPABASE_URL      → "Project URL" at the top of the page
#   NEXT_PUBLIC_SUPABASE_ANON_KEY → "Publishable and secret API keys" tab → Publishable key (sb_publishable_...)
#   SUPABASE_SERVICE_ROLE_KEY     → "Publishable and secret API keys" tab → Secret key (sb_secret_...)
#
# Note: Supabase now uses Publishable/Secret keys (not the legacy anon/service_role JWT keys).
# The legacy tab still works but the new keys are recommended for all new projects.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Set automatically by Vercel, do not set manually
VERCEL_ENV=
